{
  "name": "fleet-management-backend",
  "version": "1.0.0",
  "description": "Fleet Management System API Server",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seed.js",
    "setup:maps": "node scripts/setup-google-maps.js",
    "seed:dashboard": "node scripts/seed-dashboard.js",
    "test:auth": "node scripts/test-auth.js",
    "test:dashboard": "node scripts/test-dashboard.js",
    "test:vehicles": "node scripts/test-vehicles.js",
    "test:drivers": "node scripts/test-drivers.js",
    "test:gps": "node scripts/test-gps.js",
    "test:routes": "node scripts/test-routes.js",
    "test:fuel": "node scripts/test-fuel.js",
    "test:maintenance": "node scripts/test-maintenance.js",
    "test:documents": "node scripts/test-documents.js",
    "test:trips": "node scripts/test-trips.js",
    "test:alerts": "node scripts/test-alerts.js",
    "test:reports": "node scripts/test-reports.js",
    "test:admin": "node scripts/test-admin.js",
    "test:maps": "node scripts/test-maps.js",
    "test:unit": "node --test tests/unit/geoUtils.test.js tests/unit/polylineUtils.test.js tests/unit/pagination.test.js tests/unit/roles.test.js",
    "test:integration": "node scripts/run-all-tests.js",
    "test:all": "npm run test:unit && npm run test:integration",
    "test": "npm run test:all"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "pdfkit": "^0.16.0",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.1.9",
    "socket.io-client": "^4.8.1"
  }
}
